# ═══════════════════════════════════════════════
#  PRO MEDIA – Environment Variables Template
#  Copy this file → rename to .env and fill in real values
#  NEVER commit .env to Git!
# ═══════════════════════════════════════════════

# ─── SERVER ─────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=*

# ─── SMS PANEL (adbizzdigital) ──────────────────
SMS_API_URL=https://login.adbizzdigital.com/sms-panel/api/http/index.php
SMS_USERNAME=your_panel_username
SMS_API_KEY=your_rotated_api_key
SMS_SENDER_ID=YTWONX
SMS_TEMPLATE_ID=your_dlt_template_id
# Must match the DLT-registered template text exactly; {#var#} is replaced with the OTP at send-time.
SMS_TEMPLATE_TEXT=Your OTP for registration is {#var#}. Valid for 10 Mins. KSN Lunch Box Y2nx
